# Local Node adapter. Supabase Edge Functions ignore PORT and HOST.
PORT=8787
HOST=127.0.0.1
NODE_ENV=development

# Server-only OpenAI access. Never copy this into Gradle, Android resources, or the APK.
OPENAI_API_KEY=
OPENAI_MODEL_PROFILE=budget
# OPENAI_ASK_MODEL=gpt-5.4-mini
# OPENAI_REMEMBER_MODEL=gpt-5.4-nano
# OPENAI_COMPLEX_MODEL=gpt-5.6-luna
# OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-realtime-whisper
# OPENAI_REALTIME_MODEL=gpt-realtime-2.1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_IMAGE_MODEL=gpt-image-1-mini

# One deployment-wide semantic model. Never mix providers in the same index.
EMBEDDING_PROVIDER=gte-small

# Random 32+ character server secret used for installation tokens and destructive confirmations.
INSTALLATION_TOKEN_SECRET=

# Supabase project configuration. Use the newer sb_publishable_ and sb_secret_ keys.
# NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY are also
# accepted for compatibility with values copied from a Next.js Supabase setup.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Base64 or high-entropy 32+ byte material. Add V2 before rotating; keep V1 until all rows are re-encrypted.
CLOUD_MEMORY_MASTER_KEY_V1=

# Public deployed MCP protected-resource base URL, without a trailing slash.
MCP_RESOURCE_URL=

# Ed25519 PEM. For Supabase secrets, preserve line breaks or use literal \n sequences.
POLICY_SIGNING_PRIVATE_KEY_PEM=
POLICY_SIGNING_PUBLIC_KEY_PEM=
# Optional JSON map of package name to trusted SHA-256 signing-certificate fingerprints.
POLICY_CERTIFICATE_FINGERPRINTS_JSON={}

# Google web OAuth client shared by Supabase Google sign-in and Calendar authorization.
GOOGLE_OAUTH_WEB_CLIENT_ID=
GOOGLE_OAUTH_WEB_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=

# Play Integrity server verification. JSON is the complete service-account document.
PLAY_INTEGRITY_SERVICE_ACCOUNT_JSON=
PLAY_PACKAGE_NAME=com.contextbubble.app.play

# Private Lab registration credential. Android receives the matching LAB_INVITE_CREDENTIAL only for Lab builds.
LAB_INVITE_SECRET=

# Free-tier cost controls.
DAILY_ASSIST_REQUESTS=100
DAILY_IMAGE_REQUESTS=10
DAILY_REALTIME_MINUTES=30
DAILY_TRANSCRIPTION_MINUTES=60
CLOUD_BLOB_BYTES_PER_USER=100000000

MINIMUM_ANDROID_VERSION=33
API_COMPATIBILITY_VERSION=2

# Production rollout switches. Production keeps each capability off until its
# dev-project gates pass. Local development defaults configured features on
# when these variables are omitted.
ENABLE_CLOUD_MEMORY=false
ENABLE_SEMANTIC_SEARCH=false
ENABLE_MCP=false
ENABLE_REALTIME_VOICE=false
ENABLE_CALENDAR=false
ENABLE_SIGNED_POLICIES=false

# Operations-only variables used by scripts/backup-cloud.mjs, not Edge Functions.
# SUPABASE_DB_URL=postgresql://...
# BACKUP_ENCRYPTION_KEY=base64-encoded-32-byte-key
# BACKUP_DIRECTORY=C:\secure\context-bubble-backups

# Retrieval gate only. Use a disposable dev user and never persist its token.
# RETRIEVAL_EVAL_BACKEND_URL=https://PROJECT.supabase.co/functions/v1/api
# RETRIEVAL_EVAL_ACCESS_TOKEN=
# RETRIEVAL_EVAL_CONFIRM=I_AM_USING_A_DISPOSABLE_DEV_USER
