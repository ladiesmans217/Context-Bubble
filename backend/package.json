{
  "name": "context-bubble-backend",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.scripts.json",
    "test": "tsx --test src/**/*.test.ts",
    "reembed:cloud": "tsx --env-file-if-exists=.env scripts/reembed-cloud.ts",
    "eval:retrieval": "tsx --env-file-if-exists=.env scripts/evaluate-retrieval.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.11",
    "@supabase/supabase-js": "^2.110.8",
    "hono": "^4.12.31",
    "jose": "^6.1.3",
    "mcp-lite": "^0.10.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
